{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aispec.dev/schema/agent-identity.schema.json",
  "title": "AgentIdentity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "org_id",
    "team_id",
    "display_name",
    "framework",
    "environment",
    "created_at",
    "created_by",
    "status",
    "tags"
  ],
  "properties": {
    "agent_id": {
      "type": "string",
      "format": "uuid"
    },
    "org_id": {
      "type": "string"
    },
    "team_id": {
      "type": "string"
    },
    "display_name": {
      "type": "string",
      "maxLength": 128
    },
    "framework": {
      "type": "string",
      "enum": ["openclaw", "nemoclaw", "langgraph", "crewai", "autogen", "custom"]
    },
    "environment": {
      "type": "string",
      "enum": ["development", "staging", "production"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["active", "suspended", "revoked"]
    },
    "last_seen_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "tags": {
      "type": "object",
      "maxProperties": 20,
      "additionalProperties": {
        "type": ["string", "number", "boolean"]
      }
    }
  }
}
